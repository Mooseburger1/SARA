
#Golang Image
FROM golang


ARG key
ARG secret

ENV KEY=$key
ENV SECRET=$secret

WORKDIR /app

COPY ./backend /app

RUN ls

RUN go get -u github.com/rakyll/gotest

CMD ["gotest", "./...", "-v", "-cover"]
